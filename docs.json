{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Sleak internal docs",
  "custom_css": ["/custom.css"],
  "colors": {
    "primary": "#8551FB",
    "light": "#A78BFA",
    "dark": "#6B3BDB"
  },
  "favicon": "/logo/sleakfavicon.png",
  "navigation": {
    "pages": [
      {
        "group": "Internal",
        "pages": ["index"]
      },
      {
        "group": "API Reference",
        "pages": ["api-reference/introduction", "api-reference/ping"]
      }
    ]
  },
  "logo": {
    "light": "/logo/sleaklogo_full_darktext_padding.png",
    "dark": "/logo/sleaklogo_full_lighttext_padding.png"
  },
  "fonts": {
    "heading": {
      "family": "Geist",
      "source": "https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-sans/Geist-SemiBold.woff2",
      "format": "woff2",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "source": "https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-sans/Geist-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "search": {
    "location": "top"
  },
  "api": {
    "openapi": "openapi.json"
  },
  "navbar": {
    "links": [
      {
        "label": "Public Docs",
        "href": "https://docs.sleak.chat"
      }
    ]
  },
  "footer": {}
}
